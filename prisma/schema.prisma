generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  pending
  sent
  failure
}

enum MessageType {
  discord
  email
  whatsapp
  sms
  phoneCall
}

model Message {
  id             String        @id @default(uuid())
  createdAt      DateTime      @default(now())
  status         MessageStatus @default(pending)
  sendDate       DateTime?
  title          String
  text           String
  type           MessageType
  phone          String?
  email          String?
  discordWebhook String?
  attemptCount   Int           @default(0)
  lastError      String?
  apiKeyId       Int
  apiKey         ApiKey        @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([status, sendDate])
  @@index([type])
  @@index([createdAt])
  @@index([apiKeyId, createdAt])
}

model ApiKey {
  id             Int       @id @default(autoincrement())
  key            String
  keyHash        String    @unique
  limit          Int
  lastSend       DateTime?
  totalMensagens Int       @default(0)
  name           String
  createdAt      DateTime  @default(now())
  messages       Message[]

  @@index([name])
}
